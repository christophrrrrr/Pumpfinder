# ── Pump configuration ──────────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in the values.
# All services below have free tiers. The app runs with only APP_PASSWORD +
# SESSION_SECRET set; the rest unlock optional features (see notes).

# Login (required). The single password your mom uses to sign in.
APP_PASSWORD=change-me

# Session cookie encryption key (required). Must be at least 32 characters.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# AI summaries + verdict (Google Gemini, free tier). Get a key at
# https://aistudio.google.com/apikey . Without this, cards still show data but
# no AI summary/verdict.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Lookup history persistence (optional). A Postgres CONNECTION STRING — NOT a
# Supabase API key. In Supabase: Project Settings → Database → Connection string
# → URI (use the pooler URI for serverless). Looks like:
#   postgresql://postgres.<ref>:<password>@aws-0-...pooler.supabase.com:6543/postgres
# Without this, history works in-memory and resets on restart.
DATABASE_URL=
